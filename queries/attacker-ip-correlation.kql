// ============================================================
// Wireshark - Sentinel Correlation
// Attacker IPs captured in the pcap, matched against Sentinel syslog
// MITRE ATT&CK: T1110.001 — Brute Force: Password Guessing
// ============================================================

let AttackerIPs = dynamic([
    "3.22.234.7",
    "65.20.143.45",
    "65.20.217.64",
    "80.94.95.115",
    "80.94.95.116",
    "83.239.171.226",
    "88.214.25.124",
    "121.128.84.224",
    "183.89.250.247"
]);

// Query 1 — Confirm captured IPs appear in Sentinel syslog
Syslog
| where TimeGenerated > ago(7d)
| where Facility in ("auth", "authpriv")
| extend SourceIP = extract(@"from (\d+\.\d+\.\d+\.\d+)", 1, SyslogMessage)
| where SourceIP in (AttackerIPs)
| summarize Attempts = count(), FirstSeen = min(TimeGenerated), LastSeen = max(TimeGenerated) by SourceIP
| sort by Attempts desc

// ============================================================
// Query 2 — Brute force detection rule: 10+ failures in 1 hour
// ============================================================
Syslog
| where TimeGenerated > ago(1h)
| where Facility in ("auth", "authpriv")
| where SyslogMessage has_any ("Failed password", "authentication failure", "Invalid user")
| extend SourceIP = extract(@"from (\d+\.\d+\.\d+\.\d+)", 1, SyslogMessage)
| where isnotempty(SourceIP)
| summarize FailedAttempts = count() by SourceIP, bin(TimeGenerated, 1h)
| where FailedAttempts >= 10
| sort by FailedAttempts desc

// ============================================================
// Query 3 — Triage: did any attacker IP successfully log in?
// Empty result = no unauthorized access. That is the win.
// ============================================================
let AttackerIPs = dynamic([
    "3.22.234.7", "65.20.143.45", "65.20.217.64", "80.94.95.115",
    "80.94.95.116", "83.239.171.226", "88.214.25.124",
    "121.128.84.224", "183.89.250.247"
]);
Syslog
| where TimeGenerated > ago(7d)
| where SyslogMessage has "Accepted password"
| extend SourceIP = extract(@"from (\d+\.\d+\.\d+\.\d+)", 1, SyslogMessage)
| where SourceIP in (AttackerIPs)
| project TimeGenerated, SourceIP, SyslogMessage
